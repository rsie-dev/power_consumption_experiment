from pathlib import Path

from experiment.api import get_experiment_builder

run_count = {{template_args.runs}}

experiment = (get_experiment_builder()
            .on_host("{{template_args.host}}", "{{template_args.ip}}")

              .measure_with_multimeter("{{template_args.multimeter}}")
{% if template_args.mon_temp %}
              .control_temperature({{template_args.mon_temp}})
{% endif %}
{% if not template_args.with_timers %}
              .disable_timers()
{% endif %}
{% if not template_args.with_caches %}
              .with_clear_cache()
{% endif %}

              .measure_runs(run_count, "baseline")
                .execute_with("/usr/bin/sleep {{sleep_time}}s")
                  .with_timings()
                .done()
              .done()
            .done()
            .build()
            )
