{% from 'measurement.jinja' import measurement %}
from pathlib import Path

from experiment.api import get_experiment_builder

# Generate scripts for:  {{ template_args.host }}
# Using tools:           {{ tools | join(', ') }}
# Using data sets:       {{ input_sets | join(', ') }}
# Using strengths:       {{ strengths | join(', ') }}
# Using operation modes: {{ modes | join(', ') }}


run_count = {{template_args.runs}}
{% if template_args.head_delay %}
head_delay = {{template_args.head_delay}}
{% endif %}
{% if template_args.tail_delay %}
tail_delay = {{template_args.tail_delay}}
{% endif %}

local_path = Path("{{template_args.data_folder}}")
{% for data_set in data_sets %}
local_{{data_set.data_set_name}} = local_path / "{{data_set.data_set_file}}"
{% endfor %}

remote_path = Path("/tmp")
{% for data_set in data_sets %}
remote_{{data_set.data_set_name}} = remote_path / "{{data_set.data_set_file}}"
{% endfor %}


experiment = (get_experiment_builder()
            .on_host("{{template_args.host}}", "{{template_args.ip}}")
              .initialize()
{% for data_set in data_sets %}
                .upload(local_{{data_set.data_set_name}}, remote_path)
{% endfor %}
              .done()

{% if template_args.warmup %}
              .with_warmup()
                .execute_with("stress-ng --cpu 0 --timeout {{template_args.warmup}}s")
                  .with_work_dir("/tmp")
                .done()
              .done()
{% endif %}

              .measure_with_multimeter("{{template_args.multimeter}}")
{% if template_args.mon_temp %}
              .control_temperature({{template_args.mon_temp}})
{% endif %}
{% if not template_args.with_timers %}
              .disable_timers()
{% endif %}
{% if not template_args.with_caches %}
              .with_clear_cache()
{% endif %}

{% for data_set in data_sets %}
              {% for tool in data_set.tools %}
              {{ measurement(template_args, tool.tool, tool.measurement_tags, tool.tool_args, data_set.data_set_name) }}
              {% endfor %}
{% endfor %}
              .shutdown()
{% for data_set in data_sets %}
                .delete(remote_{{data_set.data_set_name}})
{% endfor %}
              .done()
            .done()
            .build()
            )

