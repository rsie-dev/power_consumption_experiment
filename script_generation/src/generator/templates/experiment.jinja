{% from 'measurement.jinja' import measurement %}
from pathlib import Path

from experiment.api import get_experiment_builder

remote_path = Path("/tmp")

experiment = (get_experiment_builder()
            .on_host("{{host}}", "{{ip}}")
              .upload(Path("{{data_folder}}", "{{data_set.data_file}}"), remote_path)

              {% for tool in tools %}
              {{ measurement(args, tool.tool, tool.tool_tags, tool.tool_args, data_set) }}
              {% endfor %}

              .delete(remote_path / data_set.data_file.name)
            .done()
            .build()
            )

