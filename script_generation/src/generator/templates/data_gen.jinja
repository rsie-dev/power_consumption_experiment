from pathlib import Path

from experiment.api import get_experiment_builder

{% if args.head_delay %}
head_delay = {{args.head_delay}}
{% endif %}
{% if args.tail_delay %}
tail_delay = {{args.tail_delay}}
{% endif %}

local_path = Path("{{args.data_folder}}")
{% for data_set in data_sets_in %}
local_{{data_set.data_set_name}} = local_path / "{{data_set.data_set_file}}"
{% endfor %}

remote_path = Path("/tmp")
{% for data_set in data_sets_in %}
remote_{{data_set.data_set_name}} = remote_path / "{{data_set.data_set_file}}"
{% endfor %}

{% for data_set in data_sets %}
target_{{data_set.target_name}} = remote_path / "{{data_set.target_file}}"
{% endfor %}

{% macro measurement(args, tool, measurement_tags, tool_args, data_set_name, target_name) %}
.measure_runs(1, "{{ measurement_tags | join("_") }}")
                .execute_with("{{tool.value.binary}} {{tool_args}} %s" % (remote_{{data_set_name}}))
                  .with_timings()
                  .count_stdout(target_{{target_name}})
                .done()
              .done()
{% endmacro %}

experiment = (get_experiment_builder()
            .on_host("{{args.host}}", "{{args.ip}}")
              .initialize()
{% for data_set in data_sets_in %}
                .upload(local_{{data_set.data_set_name}}, remote_path)
{% endfor %}
              .done()

              .measure_with_multimeter("{{args.multimeter}}")

{% for data_set in data_sets %}
              {% for tool in data_set.tools %}
              {{ measurement(args, tool.tool, tool.measurement_tags, tool.tool_args, data_set.data_set_name, data_set.target_name) }}
              {% endfor %}
{% endfor %}
              .shutdown()
{% for data_set in data_sets_in %}
                .delete(remote_{{data_set.data_set_name}})
{% endfor %}
{% for data_set in data_sets %}
                .download(target_{{data_set.target_name}}, "data_gen")
                .delete(target_{{data_set.target_name}})
{% endfor %}
              .done()
            .done()
            .build()
            )
