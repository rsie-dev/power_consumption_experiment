{% from 'measurement.jinja' import measurement %}
from pathlib import Path

from experiment.api import get_experiment_builder

remote_path = Path("/tmp")

experiment = (get_experiment_builder()
            .on_host("{{args.host}}", "{{args.ip}}")
{% for data_set in data_sets %}
              .upload(Path("{{args.data_folder}}", "{{data_set.data_set.data_file}}"), remote_path)

              {% for tool in data_set.tools %}
              {{ measurement(args, tool.tool, tool.measurement_tags, tool.tool_args, data_set.data_set) }}
              {% endfor %}
              .delete(remote_path / "{{data_set.data_set.data_file}}")

{% endfor %}
            .done()
            .build()
            )

